{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: format solution",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "format",
                "KubeUI.slnx",
                "--verbosity",
                "minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "XAML Styler: Format KubeUI.Avalonia",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "dnx",
                "XamlStyler.Console",
                "-r",
                "-d",
                "src\\KubeUI.Avalonia",
                "-c",
                "Settings.XamlStyler"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "format: all",
            "dependsOn": [
                "dotnet: format solution",
                "XAML Styler: Format KubeUI.Avalonia"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "dotnet: build solution",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "KubeUI.slnx"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
