<UserControl
    x:Class="KubeUI.V1SecretProperties"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:KubeUI.Controls"
    xmlns:converters="using:KubeUI.Resources.Configuration.V1Secret.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:k8s.Models"
    xmlns:views="using:KubeUI.Views"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    x:DataType="models:V1Secret"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ByteArrayToStringConverter x:Key="ByteArrayToStringConverter" />
    </UserControl.Resources>
    <StackPanel>
        <c:ExpandableSection Header="Data" IsExpanded="True">
            <ItemsControl ItemsSource="{Binding Data}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <c:PropertyItem Key="{Binding Key}" Value="{Binding Value, Converter={StaticResource ByteArrayToStringConverter}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </c:ExpandableSection>

        <c:ExpandableSection Header="Certificates" IsExpanded="True">
            <ItemsControl ItemsSource="{Binding Data}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:CertificateItemView Bytes="{Binding Value}" Header="{Binding Key}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </c:ExpandableSection>
    </StackPanel>
</UserControl>
