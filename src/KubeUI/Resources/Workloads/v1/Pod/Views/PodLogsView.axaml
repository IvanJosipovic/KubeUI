<UserControl
    x:Class="KubeUI.Views.PodLogsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assets="using:KubeUI.Assets"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:edit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:vm="using:KubeUI.ViewModels"
    d:DesignHeight="400"
    d:DesignWidth="500"
    x:DataType="vm:PodLogsViewModel">
    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,*">
        <!--  Top bar  -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label VerticalAlignment="Center" Content="Pod:" />
            <Label VerticalAlignment="Center">
                <Label.Content>
                    <MultiBinding StringFormat="{}{0}/{1}/{2}">
                        <Binding Path="Object.Metadata.NamespaceProperty" />
                        <Binding Path="Object.Metadata.Name" />
                        <Binding Path="ContainerName" />
                    </MultiBinding>
                </Label.Content>
            </Label>

            <ToggleButton IsChecked="{Binding Previous, Mode=TwoWay}" ToolTip.Tip="{x:Static assets:Resources.PodLogsView_Previous}">
                <ToggleButton.Content>
                    <PathIcon Data="{StaticResource arrow_undo_regular}" />
                </ToggleButton.Content>
            </ToggleButton>

            <ToggleButton IsChecked="{Binding Timestamps, Mode=TwoWay}" ToolTip.Tip="{x:Static assets:Resources.PodLogsView_Timestamps}">
                <ToggleButton.Content>
                    <PathIcon Data="{StaticResource timer_regular}" />
                </ToggleButton.Content>
            </ToggleButton>

            <ToggleButton IsChecked="{Binding AutoScrollToBottom, Mode=TwoWay}" ToolTip.Tip="{x:Static assets:Resources.PodLogsView_AutoScrollToBottom}">
                <ToggleButton.Content>
                    <PathIcon Data="{StaticResource ic_fluent_padding_down_filled}" />
                </ToggleButton.Content>
            </ToggleButton>

            <ToggleButton IsChecked="{Binding WordWrap, Mode=TwoWay}" ToolTip.Tip="{x:Static assets:Resources.PodLogsView_WordWrap}">
                <ToggleButton.Content>
                    <PathIcon Data="{StaticResource text_wrap_regular}" />
                </ToggleButton.Content>
            </ToggleButton>
        </StackPanel>

        <edit:TextEditor x:Name="TextEditorControl" Grid.Row="1"
            Background="{DynamicResource SystemAltHighColor}"
            Document="{Binding Logs, Mode=OneWay}"
            FontFamily="Cascadia Mono"
            FontSize="{Binding SettingsService.Settings.FontSize}"
            FontWeight="Normal"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            ShowLineNumbers="False"
            TextChanged="TextEditorControl_TextChanged"
            VerticalScrollBarVisibility="Visible"
            WordWrap="{Binding WordWrap}">
            <edit:TextEditor.Options>
                <edit:TextEditorOptions
                    AllowScrollBelowDocument="false"
                    EnableEmailHyperlinks="False"
                    EnableHyperlinks="false"
                    ShowBoxForControlCharacters="False" />
            </edit:TextEditor.Options>
            <edit:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Click="CopyMenuItem_Click"
                        Header="{x:Static assets:Resources.Action_Copy}"
                        HotKey="Ctrl+C">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource copy_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </edit:TextEditor.ContextMenu>
        </edit:TextEditor>
    </Grid>
</UserControl>
