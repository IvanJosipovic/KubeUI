<UserControl
    x:Class="KubeUI.Resources.Workloads.v1.Pod.Controls.PodStatusCell"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KubeUI.Resources.Workloads.v1.Pod.Controls"
    HorizontalAlignment="Left"
    VerticalAlignment="Center">
    <TextBlock
        Margin="12,0,12,0"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Foreground="{Binding Color, RelativeSource={RelativeSource AncestorType=local:PodStatusCell}}"
        Text="{Binding PrettyString, RelativeSource={RelativeSource AncestorType=local:PodStatusCell}}"
        ToolTip.Tip="{Binding PrettyString, RelativeSource={RelativeSource AncestorType=local:PodStatusCell}}">
        <TextBlock.Styles>
            <Style Selector="TextBlock">
                <Setter Property="Foreground" Value="Orange" />
            </Style>
        </TextBlock.Styles>
    </TextBlock>
</UserControl>
