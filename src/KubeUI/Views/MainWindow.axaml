<Window
    x:Class="KubeUI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:assets="using:KubeUI.Assets"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:KubeUI.Views"
    xmlns:vm="using:KubeUI.ViewModels"
    Title="KubeUI"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Icon="/Assets/icon.ico"
    UseLayoutRounding="True"
    mc:Ignorable="d"
    x:DataType="vm:MainViewModel">
    <Window.DataContext>
    <vm:MainViewModel />
     </Window.DataContext>

   <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="{x:Static assets:Resources.MainView_Menu_File}">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem
              Header="{x:Static assets:Resources.MainView_Menu_File_Clusters}"
              Command="{Binding OpenClustersCommand}" />
            <NativeMenuItem
              Header="{x:Static assets:Resources.MainView_Menu_File_Settings}"
              Command="{Binding OpenSettingsCommand}" />

            <NativeMenuItemSeparator />

            <NativeMenuItem
              Header="{x:Static assets:Resources.MainView_Menu_File_Exit}"
              Command="{Binding CloseCommand}" />
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>

      <NativeMenuItem Header="{x:Static assets:Resources.MainView_Menu_Window}">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem
              Header="{x:Static assets:Resources.MainView_Menu_Window_ResetLayout}"
              Command="{Binding ResetLayoutCommand}" />
            <NativeMenuItem
              Header="{x:Static assets:Resources.MainView_Menu_Window_SwitchTheme}"
              Command="{Binding SwitchThemeCommand}" />
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>

      <NativeMenuItem Header="{x:Static assets:Resources.MainView_Menu_Help}">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem
              Header="{x:Static assets:Resources.MainView_Menu_Help_About}"
              Command="{Binding OpenAboutCommand}" />
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>

  <views:MainView />

</Window>
