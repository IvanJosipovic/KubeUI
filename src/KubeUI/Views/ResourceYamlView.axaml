<UserControl
    x:Class="KubeUI.Views.ResourceYamlView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:assets="clr-namespace:KubeUI.Assets"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:KubeUI"
    xmlns:vm="clr-namespace:KubeUI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ResourceYamlViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:ResourceYamlViewModel />
    </Design.DataContext>

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,*">

        <!--  Read-only toolbar  -->
        <StackPanel
            Grid.Row="0"
            IsVisible="{Binding EditMode, Converter={x:Static utils:Utilities.InverseBooleanConverter}}"
            Orientation="Horizontal">
            <Button
                Command="{Binding SetEditModeCommand}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Edit}">
                <PathIcon Data="{StaticResource document_edit_regular}" />
            </Button>
            <ToggleButton
                Command="{Binding SetHideNoisyFieldsCommand}"
                IsChecked="{Binding HideNoisyFields}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_HideNoisyFields}">
                <PathIcon Data="{StaticResource eye_hide_regular}" />
            </ToggleButton>
            <ToggleButton
                IsChecked="{Binding WordWrap}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlView_WordWrap}">
                <PathIcon Data="{StaticResource text_wrap_regular}" />
            </ToggleButton>
        </StackPanel>

        <!--  Edit toolbar  -->
        <StackPanel
            Grid.Row="0"
            IsVisible="{Binding EditMode}"
            Orientation="Horizontal">
            <Button
                Command="{Binding SaveCommand}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Save}">
                <PathIcon Data="{StaticResource save_regular}" />
            </Button>
            <Button
                Command="{Binding SetEditModeCommand}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Cancel}">
                <PathIcon Data="{StaticResource dismiss_regular}" />
            </Button>
            <ToggleButton
                IsChecked="{Binding WordWrap}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlView_WordWrap}">
                <PathIcon Data="{StaticResource text_wrap_regular}" />
            </ToggleButton>
        </StackPanel>

        <!--  YAML editor  -->
        <ae:TextEditor
            Name="Editor"
            Grid.Row="1"
            Background="{DynamicResource SystemAltHighColor}"
            Document="{Binding YamlDocument, Mode=TwoWay}"
            FontFamily="Cascadia Mono"
            FontSize="{Binding Settings.Settings.ConsoleFontSize}"
            FontWeight="Normal"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="{Binding EditMode, Converter={x:Static utils:Utilities.InverseBooleanConverter}}"
            ShowLineNumbers="True"
            VerticalScrollBarVisibility="Visible"
            WordWrap="{Binding WordWrap}">
            <ae:TextEditor.KeyBindings>
                <KeyBinding
                    Command="{Binding UndoCommand}"
                    Gesture="Ctrl+Z" />
            </ae:TextEditor.KeyBindings>
            <ae:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Click="CutClick"
                        Header="{x:Static assets:Resources.Action_Cut}"
                        HotKey="Ctrl+X"
                        IsVisible="{Binding EditMode}">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource cut_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="CopyClick"
                        Header="{x:Static assets:Resources.Action_Copy}"
                        HotKey="Ctrl+C">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource copy_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="PasteClick"
                        Header="{x:Static assets:Resources.Action_Paste}"
                        HotKey="Ctrl+V"
                        IsVisible="{Binding EditMode}">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource clipboard_paste_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="DeleteClick"
                        Header="{x:Static assets:Resources.Action_Delete}"
                        HotKey="Back"
                        IsVisible="{Binding EditMode}">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource delete_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator IsVisible="{Binding EditMode}" />

                    <MenuItem
                        Click="UndoClick"
                        Header="{x:Static assets:Resources.Action_Undo}"
                        HotKey="Ctrl+Z"
                        IsVisible="{Binding EditMode}">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource arrow_undo_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="RedoClick"
                        Header="{x:Static assets:Resources.Action_Redo}"
                        HotKey="Ctrl+Y"
                        IsVisible="{Binding EditMode}">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource arrow_redo_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ae:TextEditor.ContextMenu>
        </ae:TextEditor>
    </Grid>
</UserControl>
