<UserControl
    x:Class="KubeUI.Views.ResourceYamlView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:KubeUI.ViewModels"
    xmlns:assets="clr-namespace:KubeUI.Assets"
    xmlns:utils="clr-namespace:KubeUI"
    xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    x:DataType="vm:ResourceYamlViewModel"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:ResourceYamlViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

        <!-- Read-only toolbar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    IsVisible="{Binding EditMode, Converter={x:Static utils:Utilities.InverseBooleanConverter}}">
            <Button Command="{Binding SetEditModeCommand}"
                    ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Edit}">
                <PathIcon Data="{StaticResource document_edit_regular}" />
            </Button>
            <ToggleButton IsChecked="{Binding HideNoisyFields}"
                          Command="{Binding SetHideNoisyFieldsCommand}"
                          ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_HideNoisyFields}">
                <PathIcon Data="{StaticResource eye_hide_regular}" />
            </ToggleButton>
            <ToggleButton IsChecked="{Binding WordWrap}"
                          ToolTip.Tip="{x:Static assets:Resources.ResourceYamlView_WordWrap}">
                <PathIcon Data="{StaticResource text_wrap_regular}" />
            </ToggleButton>
        </StackPanel>

        <!-- Edit toolbar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    IsVisible="{Binding EditMode}">
            <Button Command="{Binding SaveCommand}"
                    ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Save}">
                <PathIcon Data="{StaticResource save_regular}" />
            </Button>
            <Button Command="{Binding SetEditModeCommand}"
                    ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Cancel}">
                <PathIcon Data="{StaticResource dismiss_regular}" />
            </Button>
            <ToggleButton IsChecked="{Binding WordWrap}"
                          ToolTip.Tip="{x:Static assets:Resources.ResourceYamlView_WordWrap}">
                <PathIcon Data="{StaticResource text_wrap_regular}" />
            </ToggleButton>
        </StackPanel>

        <!-- YAML editor -->
        <ae:TextEditor Name="Editor"
                       Grid.Row="1"
                       Document="{Binding YamlDocument, Mode=TwoWay}"
                       FontFamily="Cascadia Mono"
                       FontSize="{Binding Settings.Settings.ConsoleFontSize}"
                       FontWeight="Normal"
                       ShowLineNumbers="True"
                       Background="{DynamicResource SystemAltHighColor}"
                       HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Visible"
                       WordWrap="{Binding WordWrap}"
                       IsReadOnly="{Binding EditMode, Converter={x:Static utils:Utilities.InverseBooleanConverter}}">
            <ae:TextEditor.KeyBindings>
                <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
            </ae:TextEditor.KeyBindings>
            <ae:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{x:Static assets:Resources.Action_Cut}"
                              HotKey="Ctrl+X"
                              IsVisible="{Binding EditMode}"
                              Click="CutClick">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource cut_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{x:Static assets:Resources.Action_Copy}"
                              HotKey="Ctrl+C"
                              Click="CopyClick">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource copy_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{x:Static assets:Resources.Action_Paste}"
                              HotKey="Ctrl+V"
                              IsVisible="{Binding EditMode}"
                              Click="PasteClick">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource clipboard_paste_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{x:Static assets:Resources.Action_Delete}"
                              HotKey="Back"
                              IsVisible="{Binding EditMode}"
                              Click="DeleteClick">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource delete_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator IsVisible="{Binding EditMode}" />

                    <MenuItem Header="{x:Static assets:Resources.Action_Undo}"
                              HotKey="Ctrl+Z"
                              IsVisible="{Binding EditMode}"
                              Click="UndoClick">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource arrow_undo_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{x:Static assets:Resources.Action_Redo}"
                              HotKey="Ctrl+Y"
                              IsVisible="{Binding EditMode}"
                              Click="RedoClick">
                        <MenuItem.Icon>
                            <PathIcon Data="{StaticResource arrow_redo_regular}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ae:TextEditor.ContextMenu>
        </ae:TextEditor>
    </Grid>
</UserControl>
