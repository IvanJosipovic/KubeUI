<UserControl
    x:Class="KubeUI.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assets="clr-namespace:KubeUI.Assets"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:doc="using:Dock.Avalonia.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:KubeUI.Views"
    xmlns:vm="clr-namespace:KubeUI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid Background="Transparent" RowDefinitions="Auto,*">
    <!-- Top Menu (hidden on macOS in code-behind) -->
    <Menu x:Name="MainMenu" Grid.Row="0" VerticalAlignment="Top">
      <MenuItem Header="{x:Static assets:Resources.MainView_Menu_File}">
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_File_LoadKubeConfig}"
                  Command="{Binding LoadKubeConfigCommand}" />
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_File_Clusters}"
                  Command="{Binding OpenClustersCommand}" />
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_File_Settings}"
                  Command="{Binding OpenSettingsCommand}" />
        <Separator />
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_File_Exit}"
                  Command="{Binding CloseCommand}" />
      </MenuItem>

      <MenuItem Header="{x:Static assets:Resources.MainView_Menu_Window}">
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_Window_ResetLayout}"
                  Command="{Binding ResetLayoutCommand}" />
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_Window_SwitchTheme}"
                  Command="{Binding SwitchThemeCommand}" />
      </MenuItem>

      <MenuItem Header="{x:Static assets:Resources.MainView_Menu_Help}">
        <MenuItem Header="{x:Static assets:Resources.MainView_Menu_Help_About}"
                  Command="{Binding OpenAboutCommand}" />
      </MenuItem>
    </Menu>

        <doc:DockControl
            Grid.Row="1"
            Margin="4"
            Layout="{Binding Layout}" />
    </Grid>
</UserControl>
