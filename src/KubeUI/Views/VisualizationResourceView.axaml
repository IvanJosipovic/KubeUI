<UserControl
    x:Class="KubeUI.Views.VisualizationResourceView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    xmlns:vm="clr-namespace:KubeUI.ViewModels"
    x:DataType="vm:VisualizationResourceViewModel"
    ClipToBounds="False"
    mc:Ignorable="d">
    <StackPanel>
        <ToolTip.Tip>
            <MultiBinding StringFormat="{} {0}/{1} {2}">
                <Binding Path="Object.ApiVersion" />
                <Binding Path="Object.Kind" />
                <Binding Path="Object.Metadata.Name" />
            </MultiBinding>
        </ToolTip.Tip>
        <Svg Path="{Binding IconPath}">
            <Svg.ContextFlyout>
                <MenuFlyout>
                    <MenuItem
                        Command="{Binding ViewPropertiesCommand}"
                        CommandParameter="{Binding Object}"
                        Header="Properties" />
                    <MenuItem
                        Command="{Binding ViewYamlCommand}"
                        CommandParameter="{Binding Object}"
                        Header="View Yaml" />
                </MenuFlyout>
            </Svg.ContextFlyout>
        </Svg>
        <TextBlock
            Width="120"
            Margin="0,0,0,0"
            ClipToBounds="false"
            TextAlignment="Center"
            TextWrapping="Wrap">
            <TextBlock.Text>
                <MultiBinding StringFormat="{} {0} {1}">
                    <Binding Path="Object.Kind" />
                    <Binding Path="Object.Metadata.Name" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </StackPanel>
</UserControl>
