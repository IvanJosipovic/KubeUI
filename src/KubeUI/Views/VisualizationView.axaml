<UserControl
    x:Class="KubeUI.Views.VisualizationView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:agc="clr-namespace:AvaloniaGraphControl;assembly=AvaloniaGraphControl"
    xmlns:controls="clr-namespace:NodifyM.Avalonia.Controls;assembly=NodifyM.Avalonia"
    xmlns:converters="clr-namespace:NodifyM.Avalonia.Converters;assembly=NodifyM.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ic="using:FluentIcons.Avalonia"
    xmlns:k8s="using:k8s.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:viewModelBase="clr-namespace:NodifyM.Avalonia.ViewModelBase;assembly=NodifyM.Avalonia"
    xmlns:viewmodels="using:KubeUI.ViewModels"
    xmlns:vm="clr-namespace:KubeUI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:VisualizationViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:VisualizationViewModel />
    </Design.DataContext>

    <UserControl.Styles />

    <Grid RowDefinitions="Auto,*">
        <!--  Left controls  -->
        <StackPanel Grid.Row="0"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <ToggleButton IsChecked="{Binding HideNoise}" ToolTip.Tip="Hide noisy resources like inactive Replica Sets">
                <ic:FluentIcon Icon="EyeOff" />
            </ToggleButton>

            <Label
                Width="200"
                VerticalContentAlignment="Center"
                Content="{Binding Resources.Count, StringFormat='Items: {0}'}" />
        </StackPanel>

        <!--  Right controls  -->
        <StackPanel Grid.Row="0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <u:MultiComboBox
                Width="300"
                MaxHeight="20"
                Classes="ClearButton"
                ItemsSource="{Binding Cluster.Namespaces}"
                SelectedItems="{Binding Cluster.SelectedNamespaces}">

                <u:MultiComboBox.SelectedItemTemplate>
                    <DataTemplate x:DataType="k8s:V1Namespace">
                        <Label Content="{Binding Metadata.Name}" />
                    </DataTemplate>
                </u:MultiComboBox.SelectedItemTemplate>

                <u:MultiComboBox.ItemTemplate>
                    <DataTemplate x:DataType="k8s:V1Namespace">
                        <Label Content="{Binding Metadata.Name}" />
                    </DataTemplate>
                </u:MultiComboBox.ItemTemplate>

            </u:MultiComboBox>
        </StackPanel>

        <!--  Editor surface  -->
        <ScrollViewer Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <ZoomBorder x:Name="ZoomBorder"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ClipToBounds="True"
                Focusable="True"
                Stretch="Uniform"
                ZoomSpeed="1.2">
                <ZoomBorder.GestureRecognizers>
                    <PinchGestureRecognizer />
                </ZoomBorder.GestureRecognizers>
                <agc:GraphPanel Name="Graph"
                    Graph="{Binding Graph}"
                    LayoutMethod="{Binding LayoutMethod}">
                    <agc:GraphPanel.DataTemplates>
                        <DataTemplate DataType="vm:VisualizationViewModel+ResourceNodeViewModel">
                            <StackPanel>
                                <ToolTip.Tip>
                                    <MultiBinding StringFormat="{} {0}/{1} {2}">
                                        <Binding Path="Resource.ApiVersion" />
                                        <Binding Path="Resource.Kind" />
                                        <Binding Path="Resource.Metadata.Name" />
                                    </MultiBinding>
                                </ToolTip.Tip>
                                <Svg
                                    Width="64"
                                    Height="64"
                                    Path="{Binding IconPath}">
                                    <Svg.ContextFlyout>
                                        <MenuFlyout />
                                    </Svg.ContextFlyout>
                                </Svg>
                                <TextBlock
                                    Width="120"
                                    Margin="0,0,0,0"
                                    ClipToBounds="false"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{} {0} {1}">
                                            <Binding Path="Resource.Kind" />
                                            <Binding Path="Resource.Metadata.Name" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </agc:GraphPanel.DataTemplates>
                </agc:GraphPanel>
            </ZoomBorder>
        </ScrollViewer>
    </Grid>
</UserControl>
