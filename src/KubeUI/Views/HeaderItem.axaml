<UserControl
    x:Class="KubeUI.Views.HeaderItem"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KubeUI.Views"
    x:DataType="local:HeaderItem">
    <StackPanel>
        <local:PropertyItem Key="{Binding Text}" Value="">
            <local:PropertyItem.Styles>
                <Style Selector="SelectableTextBlock">
                    <Setter Property="Border.Background" Value="{DynamicResource SystemAltHighColor}" />
                    <Setter Property="Border.Padding" Value="8" />
                </Style>
            </local:PropertyItem.Styles>
        </local:PropertyItem>
        <ItemsControl ItemsSource="{Binding Controls}" />
    </StackPanel>
</UserControl>
