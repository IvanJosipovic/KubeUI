<Window
    x:Class="KubeUI.Avalonia.Shell.Main.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assets="using:KubeUI.Avalonia.Assets"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:KubeUI.Avalonia.Shell.Main.Views"
    xmlns:vm="using:KubeUI.Avalonia.Shell.Main.ViewModels"
    Title="{x:Static assets:Resources.MainWindow_Title}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainViewModel"
    Icon="/Assets/icon.ico"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{x:Static assets:Resources.MainView_Menu_File}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Command="{Binding OpenClustersCommand}" Header="{x:Static assets:Resources.MainView_Menu_File_Clusters}" />
                        <NativeMenuItem Command="{Binding OpenSettingsCommand}" Header="{x:Static assets:Resources.MainView_Menu_File_Settings}" />

                        <NativeMenuItemSeparator />

                        <NativeMenuItem Command="{Binding CloseCommand}" Header="{x:Static assets:Resources.MainView_Menu_File_Exit}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="{x:Static assets:Resources.MainView_Menu_Window}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Command="{Binding ResetLayoutCommand}" Header="{x:Static assets:Resources.MainView_Menu_Window_ResetLayout}" />
                        <NativeMenuItem Command="{Binding SwitchThemeCommand}" Header="{x:Static assets:Resources.MainView_Menu_Window_SwitchTheme}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="{x:Static assets:Resources.MainView_Menu_Help}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Command="{Binding OpenAboutCommand}" Header="{x:Static assets:Resources.MainView_Menu_Help_About}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <views:MainView />

</Window>



