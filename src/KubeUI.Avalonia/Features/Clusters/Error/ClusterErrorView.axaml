<UserControl
    x:Class="KubeUI.Avalonia.Views.ClusterErrorView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assets="clr-namespace:KubeUI.Avalonia.Assets;assembly=KubeUI.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:KubeUI.Avalonia.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ClusterErrorViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:ClusterErrorViewModel Error="Design-time error sample" />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <TextBlock
            Grid.Row="0"
            Padding="5,0,0,0"
            Text="{x:Static assets:Resources.ClusterErrorView_Header}" />
        <SelectableTextBlock
            Grid.Row="1"
            Padding="5,0,0,0"
            Text="{Binding Error}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>





