<UserControl
    x:Class="KubeUI.Avalonia.Features.Resources.Yaml.Views.ResourceYamlView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:assets="clr-namespace:KubeUI.Avalonia.Assets;assembly=KubeUI.Avalonia"
    xmlns:behaviors="using:KubeUI.Avalonia.Features.Resources.Yaml.Behaviors"
    xmlns:converters="using:KubeUI.Avalonia.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="using:FluentAvalonia.UI.Controls"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    xmlns:ic="using:FluentIcons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:KubeUI.Avalonia.Features.Resources.Yaml.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ResourceYamlViewModel"
    mc:Ignorable="d">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,Auto,*">

        <!--  Read-only toolbar  -->
        <StackPanel Grid.Row="0"
            IsVisible="{Binding !EditMode}"
            Orientation="Horizontal">
            <Button Command="{Binding SetEditModeCommand}" ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Edit}">
                <ic:FluentIcon Icon="DocumentEdit" />
            </Button>
            <ToggleButton Name="HideNoisyFieldsToggle"
                IsChecked="{Binding HideNoisyFields, Mode=TwoWay}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_HideNoisyFields}">
                <ic:FluentIcon Icon="EyeOff" />
            </ToggleButton>
            <ToggleButton IsChecked="{Binding WordWrap}" ToolTip.Tip="{x:Static assets:Resources.ResourceYamlView_WordWrap}">
                <ic:FluentIcon Icon="TextWrap" />
            </ToggleButton>
        </StackPanel>

        <!--  Edit toolbar  -->
        <StackPanel Grid.Row="0"
            IsVisible="{Binding EditMode}"
            Orientation="Horizontal">
            <Button
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding CanSaveAction}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Save}">
                <ic:FluentIcon Icon="Save" />
            </Button>
            <Button
                Command="{Binding DryRunCommand}"
                IsEnabled="{Binding CanDryRunAction}"
                ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_DryRun}">
                <ic:FluentIcon Icon="CheckmarkCircle" />
            </Button>
            <Button Command="{Binding SetEditModeCommand}" ToolTip.Tip="{x:Static assets:Resources.ResourceYamlViewer_Cancel}">
                <ic:FluentIcon Icon="Dismiss" />
            </Button>
            <ToggleButton IsChecked="{Binding WordWrap}" ToolTip.Tip="{x:Static assets:Resources.ResourceYamlView_WordWrap}">
                <ic:FluentIcon Icon="TextWrap" />
            </ToggleButton>
        </StackPanel>

        <fa:InfoBar Name="ActionResultBar" Grid.Row="1"
            Title="{Binding ActionResultTitle}"
            Margin="4"
            CloseButtonCommand="{Binding DismissActionResultCommand}"
            IsClosable="True"
            IsOpen="{Binding HasActionResult}"
            IsVisible="{Binding HasActionResult}"
            Message="{Binding ActionResultMessage}"
            Severity="{Binding ActionResultSeverity}" />

        <!--  YAML editor  -->
        <ae:TextEditor Name="Editor" Grid.Row="2"
            Background="{DynamicResource SystemAltHighColor}"
            FontFamily="Cascadia Mono"
            FontSize="{Binding Settings.Appearance.ConsoleFontSize}"
            FontWeight="Normal"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="{Binding !EditMode}"
            ShowLineNumbers="True"
            VerticalScrollBarVisibility="Visible"
            WordWrap="{Binding WordWrap}">
            <ae:TextEditor.Options>
                <ae:TextEditorOptions
                    ConvertTabsToSpaces="True"
                    EnableEmailHyperlinks="False"
                    EnableHyperlinks="False"
                    HighlightCurrentLine="True"
                    IndentationSize="2"
                    ShowBoxForControlCharacters="False" />
            </ae:TextEditor.Options>
            <Interaction.Behaviors>
                <behaviors:YamlEditorBehavior />
                <behaviors:YamlDiagnosticRenderingBehavior />
                <behaviors:YamlHoverToolTipBehavior />
                <behaviors:YamlEditorScrollBehavior />
            </Interaction.Behaviors>
            <ae:TextEditor.KeyBindings>
                <KeyBinding Command="{Binding RequestCompletionCommand}" Gesture="Ctrl+Space" />
                <KeyBinding Command="{Binding UndoCommand}" Gesture="Ctrl+Z" />
            </ae:TextEditor.KeyBindings>
            <ae:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Header="{x:Static assets:Resources.Action_Cut}"
                        HotKey="Ctrl+X"
                        IsVisible="{Binding EditMode}">
                        <Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="Click">
                                <ia:CallMethodAction MethodName="Cut" TargetObject="{Binding #Editor}" />
                            </ia:EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <MenuItem.Icon>
                            <ic:FluentIcon Icon="Cut" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{x:Static assets:Resources.Action_Copy}" HotKey="Ctrl+C">
                        <Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="Click">
                                <ia:CallMethodAction MethodName="Copy" TargetObject="{Binding #Editor}" />
                            </ia:EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <MenuItem.Icon>
                            <ic:FluentIcon Icon="Copy" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Header="{x:Static assets:Resources.Action_Paste}"
                        HotKey="Ctrl+V"
                        IsVisible="{Binding EditMode}">
                        <Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="Click">
                                <ia:CallMethodAction MethodName="Paste" TargetObject="{Binding #Editor}" />
                            </ia:EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <MenuItem.Icon>
                            <ic:FluentIcon Icon="ClipboardPaste" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Header="{x:Static assets:Resources.Action_Delete}"
                        HotKey="Back"
                        IsVisible="{Binding EditMode}">
                        <Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="Click">
                                <ia:CallMethodAction MethodName="Delete" TargetObject="{Binding #Editor}" />
                            </ia:EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <MenuItem.Icon>
                            <ic:FluentIcon Icon="Delete" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator IsVisible="{Binding EditMode}" />

                    <MenuItem
                        Header="{x:Static assets:Resources.Action_Undo}"
                        HotKey="Ctrl+Z"
                        IsVisible="{Binding EditMode}">
                        <Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="Click">
                                <ia:CallMethodAction MethodName="Undo" TargetObject="{Binding #Editor}" />
                            </ia:EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <MenuItem.Icon>
                            <ic:FluentIcon Icon="ArrowUndo" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Header="{x:Static assets:Resources.Action_Redo}"
                        HotKey="Ctrl+Y"
                        IsVisible="{Binding EditMode}">
                        <Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="Click">
                                <ia:CallMethodAction MethodName="Redo" TargetObject="{Binding #Editor}" />
                            </ia:EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <MenuItem.Icon>
                            <ic:FluentIcon Icon="ArrowRedo" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ae:TextEditor.ContextMenu>
        </ae:TextEditor>
    </Grid>
</UserControl>
