<Expander
    x:Class="KubeUI.Avalonia.Features.Resources.Properties.Controls.ExpandableSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    d:DesignHeight="400"
    d:DesignWidth="400"
    IsExpanded="True">
    <Expander.Resources>
        <x:Double x:Key="ExpanderMinHeight">28</x:Double>
        <Thickness x:Key="ExpanderHeaderPadding">10,0,0,0</Thickness>
        <Thickness x:Key="ExpanderChevronMargin">8,0,4,0</Thickness>
        <x:Double x:Key="ExpanderChevronButtonSize">24</x:Double>
        <Thickness x:Key="ExpanderContentPadding">0</Thickness>
    </Expander.Resources>
</Expander>
