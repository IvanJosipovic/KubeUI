<Expander
    x:Class="KubeUI.Avalonia.Features.Resources.Properties.Controls.ExpandableSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    MinHeight="30"
    Padding="5"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    d:DesignHeight="400"
    d:DesignWidth="400">
    <Expander.Styles>
        <Style Selector="ToggleButton">
            <Setter Property="Padding" Value="8" />
        </Style>
    </Expander.Styles>
</Expander>





