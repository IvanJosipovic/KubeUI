<UserControl
    x:Class="KubeUI.Avalonia.Features.Resources.Properties.Controls.MetricsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:KubeUI.Avalonia.Features.Resources.Properties.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ic="using:FluentIcons.Avalonia"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    xmlns:local="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:Interaction="using:Avalonia.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:KubeUI.Avalonia.Features.Clusters.Overview.ViewModels"
    d:DesignHeight="360"
    d:DesignWidth="760"
    mc:Ignorable="d">
    <local:ExpandableSection Header="Metrics" IsExpanded="True">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch" RowSpacing="8">
            <local:PropertyItem
                Key="Status"
                IsVisible="{Binding ShowStatus, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                Value="{Binding StatusText, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />

            <Grid
                Grid.Row="1"
                IsVisible="{Binding ClusterOverviewMode, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                RowDefinitions="Auto,Auto,Auto"
                RowSpacing="8">
                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                    <ComboBox
                        Width="132"
                        ItemsSource="{Binding ClusterScopeOptions, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        SelectedItem="{Binding SelectedClusterScope, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        ToolTip.Tip="Select which cluster nodes are included in the summary.">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:ClusterScopeOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox
                        Grid.Column="1"
                        Width="132"
                        ItemsSource="{Binding ClusterTimeRangeOptions, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        SelectedItem="{Binding SelectedTimeRange, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        ToolTip.Tip="Select the time range used for cluster overview charts.">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:MetricTimeRangeOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                    <ToggleButton
                        Padding="8,6"
                        Tag="CPU"
                        IsChecked="{Binding ClusterOverviewModes[0].IsSelected, RelativeSource={RelativeSource AncestorType=local:MetricsControl}, Mode=TwoWay}"
                        Checked="ClusterOverviewMode_Checked"
                        ToolTip.Tip="CPU">
                        <ic:FluentIcon Icon="Pulse" />
                    </ToggleButton>
                    <ToggleButton
                        Padding="8,6"
                        Tag="Memory"
                        IsChecked="{Binding ClusterOverviewModes[1].IsSelected, RelativeSource={RelativeSource AncestorType=local:MetricsControl}, Mode=TwoWay}"
                        Checked="ClusterOverviewMode_Checked"
                        ToolTip.Tip="Memory">
                        <ic:FluentIcon Icon="Storage" />
                    </ToggleButton>
                </StackPanel>

                <Grid Grid.Row="2" ColumnDefinitions="2*,*,*,*" ColumnSpacing="12">
                    <Border Classes="overview-card" Padding="12">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <local:ResponsiveCartesianChart
                                Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                Title="{Binding ClusterTrendChart.ChartTitle, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                                Series="{Binding ClusterTrendChart.Series, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                                XAxes="{Binding ClusterTrendChart.XAxes, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                                YAxes="{Binding ClusterTrendChart.YAxes, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Classes="overview-card" Padding="12">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <TextBlock Classes="overview-section" HorizontalAlignment="Center" Text="{Binding ClusterCpuChart.Title, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                            <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                                <lvc:PieChart
                                    ClipToBounds="False"
                                    Height="160"
                                    InitialRotation="270"
                                    MaxValue="{Binding ClusterCpuChart.MaxValue, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                                    TooltipPosition="Auto"
                                    Series="{Binding ClusterCpuChart.Series, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                                <ItemsControl
                                    Grid.Row="1"
                                    ItemsSource="{Binding ClusterCpuChart.LegendItems, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ClusterOverviewRingChartLegendItemViewModel">
                                            <StackPanel Margin="0,0,0,6" Orientation="Vertical" Spacing="1">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Border Width="10" Height="10" Background="{Binding Color}" />
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                </StackPanel>
                                                <TextBlock Classes="overview-muted" Margin="16,0,0,0" Text="{Binding Value}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Classes="overview-card" Padding="12">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <TextBlock Classes="overview-section" HorizontalAlignment="Center" Text="{Binding ClusterMemoryChart.Title, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                            <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                                <lvc:PieChart
                                    ClipToBounds="False"
                                    Height="160"
                                    InitialRotation="270"
                                    MaxValue="{Binding ClusterMemoryChart.MaxValue, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                                    TooltipPosition="Auto"
                                    Series="{Binding ClusterMemoryChart.Series, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                                <ItemsControl
                                    Grid.Row="1"
                                    ItemsSource="{Binding ClusterMemoryChart.LegendItems, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ClusterOverviewRingChartLegendItemViewModel">
                                            <StackPanel Margin="0,0,0,6" Orientation="Vertical" Spacing="1">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Border Width="10" Height="10" Background="{Binding Color}" />
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                </StackPanel>
                                                <TextBlock Classes="overview-muted" Margin="16,0,0,0" Text="{Binding Value}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Grid.Column="3" Classes="overview-card" Padding="12">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <TextBlock Classes="overview-section" HorizontalAlignment="Center" Text="{Binding ClusterPodChart.Title, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                            <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                                <lvc:PieChart
                                    ClipToBounds="False"
                                    Height="160"
                                    InitialRotation="270"
                                    MaxValue="{Binding ClusterPodChart.MaxValue, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                                    TooltipPosition="Auto"
                                    Series="{Binding ClusterPodChart.Series, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
                                <ItemsControl
                                    Grid.Row="1"
                                    ItemsSource="{Binding ClusterPodChart.LegendItems, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ClusterOverviewRingChartLegendItemViewModel">
                                            <StackPanel Margin="0,0,0,6" Orientation="Vertical" Spacing="1">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Border Width="10" Height="10" Background="{Binding Color}" />
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                </StackPanel>
                                                <TextBlock Classes="overview-muted" Margin="16,0,0,0" Text="{Binding Value}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid
                Grid.Row="2"
                IsVisible="{Binding ShowTabs, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                RowDefinitions="Auto,Auto"
                RowSpacing="6">
                <Grid ColumnDefinitions="Auto,*">
                    <ComboBox
                        Width="132"
                        IsVisible="{Binding ShowTimeRangeSelector, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        ItemsSource="{Binding TimeRangeOptions, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        SelectedItem="{Binding SelectedTimeRange, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        ToolTip.Tip="Select the time range used for Prometheus queries.">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:MetricTimeRangeOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ListBox
                        Grid.Column="1"
                        AutoScrollToSelectedItem="False"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding Tabs, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        SelectedItem="{Binding SelectedTab, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                        SelectionMode="Single">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local:MetricTabViewModel">
                                <ToggleButton
                                    IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}"
                                    ToolTip.Tip="{Binding Title}">
                                    <ic:FluentIcon
                                        FontSize="14"
                                        Icon="{Binding Icon}" />
                                </ToggleButton>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                </Grid>

                <ContentControl
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    Content="{Binding SelectedTab, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="local:MetricTabViewModel">
                            <ItemsControl
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding Panels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Styles>
                                    <Style Selector="ItemsControl > ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.Styles>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:MetricPanelViewModel">
                                        <Grid HorizontalAlignment="Stretch" RowDefinitions="190">
                                            <local:ResponsiveCartesianChart
                                                HorizontalAlignment="Stretch"
                                                Title="{Binding ChartTitle}"
                                                Series="{Binding Series}"
                                                XAxes="{Binding XAxes}"
                                                YAxes="{Binding YAxes}">
                                                <Interaction.Behaviors>
                                                    <behaviors:ChartWheelScrollBehavior />
                                                </Interaction.Behaviors>
                                            </local:ResponsiveCartesianChart>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>

            <ItemsControl
                Grid.Row="3"
                IsVisible="{Binding ShowCurrentMetrics, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                ItemsSource="{Binding CurrentMetrics, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="120" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:MetricSummaryItemViewModel">
                        <StackPanel Margin="0,0,10,6" Spacing="1">
                            <TextBlock
                                FontSize="10"
                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                Text="{Binding Key}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="{Binding Value}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </local:ExpandableSection>
</UserControl>
