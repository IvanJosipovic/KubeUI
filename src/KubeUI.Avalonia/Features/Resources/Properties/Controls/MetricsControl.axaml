<UserControl
    x:Class="KubeUI.Avalonia.Features.Resources.Properties.Controls.MetricsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:local="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="320"
    d:DesignWidth="640"
    mc:Ignorable="d">
    <local:ExpandableSection Header="Metrics" IsExpanded="True">
        <Border Padding="8,4,8,8">
            <lvc:CartesianChart
                Height="220"
                Series="{Binding Series, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}"
                XAxes="{Binding XAxes, RelativeSource={RelativeSource AncestorType=local:MetricsControl}}" />
        </Border>
    </local:ExpandableSection>
</UserControl>
