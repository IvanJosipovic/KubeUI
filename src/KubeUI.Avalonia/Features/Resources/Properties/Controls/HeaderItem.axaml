<UserControl
    x:Class="KubeUI.Avalonia.Features.Resources.Properties.Controls.HeaderItem"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="using:KubeUI.Avalonia.Converters"
    xmlns:local="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    d:DesignHeight="30"
    d:DesignWidth="200">
    <UserControl.Resources>
        <converters:ResourceLabelConverter x:Key="ResourceLabelConverter" />
    </UserControl.Resources>
    <StackPanel>
        <local:PropertyItem Key="{Binding Text, RelativeSource={RelativeSource AncestorType=local:HeaderItem}}" Value="">
            <local:PropertyItem.Styles>
                <Style Selector="SelectableTextBlock">
                    <Setter Property="Border.Background" Value="{DynamicResource SystemAltHighColor}" />
                    <Setter Property="Border.Padding" Value="8" />
                </Style>
            </local:PropertyItem.Styles>
        </local:PropertyItem>
    </StackPanel>
</UserControl>



