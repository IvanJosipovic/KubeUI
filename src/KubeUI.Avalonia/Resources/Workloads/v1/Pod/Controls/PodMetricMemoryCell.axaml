<UserControl
    x:Class="KubeUI.Avalonia.Resources.Workloads.v1.Pod.Controls.PodMetricMemoryCell"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KubeUI.Avalonia.Resources.Workloads.v1.Pod.Controls"
    HorizontalAlignment="Left"
    VerticalAlignment="Center">
    <TextBlock
        Margin="12,0,12,0"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Text="{Binding PrettyString, RelativeSource={RelativeSource AncestorType=local:PodMetricMemoryCell}}"
        ToolTip.Tip="{Binding PrettyString, RelativeSource={RelativeSource AncestorType=local:PodMetricMemoryCell}}" />
</UserControl>



