<UserControl
    x:Class="KubeUI.Avalonia.Resources.Core.v1.Namespace.Views.PropertiesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    xmlns:m="using:KubeUI.Avalonia.Features.Resources.Metrics.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2006"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:k8s.Models"
    d:DesignHeight="220"
    d:DesignWidth="450"
    x:DataType="models:V1Namespace"
    mc:Ignorable="d">
    <StackPanel>
        <c:PropertyItem Key="Phase" Value="{Binding Status.Phase}" />
        <m:MetricsControl />
        <c:PropertyItem Key="Finalizers" Value="{Binding Spec.Finalizers.Count}" />
        <c:PropertyItem Key="Conditions" Value="{Binding Status.Conditions.Count}" />
    </StackPanel>
</UserControl>
