<UserControl
    x:Class="KubeUI.Avalonia.Resources.AccessControl.v1.ClusterRoleBinding.Views.PropertiesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:k8s.Models"
    d:DesignHeight="250"
    d:DesignWidth="450"
    x:DataType="models:V1ClusterRoleBinding"
    mc:Ignorable="d">
    <StackPanel>
        <c:PropertyItem Key="Role Kind" Value="{Binding RoleRef.Kind}" />
        <c:PropertyItem Key="Role Name" Value="{Binding RoleRef.Name}" />
        <c:PropertyItem Key="Subjects" Value="{Binding Subjects.Count}" />
    </StackPanel>
</UserControl>
