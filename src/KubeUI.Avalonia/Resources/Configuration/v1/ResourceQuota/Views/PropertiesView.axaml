<UserControl
    x:Class="KubeUI.Avalonia.Resources.Configuration.v1.ResourceQuota.Views.PropertiesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assets="using:KubeUI.Avalonia.Assets"
    xmlns:c="using:KubeUI.Avalonia.Features.Resources.Properties.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:k8s.Models"
    d:DesignHeight="250"
    d:DesignWidth="450"
    x:DataType="models:V1ResourceQuota"
    mc:Ignorable="d">
    <StackPanel>
        <c:PropertyItem Key="{x:Static assets:Resources.ResourceQuotaPropertiesView_Spec_Hard}" Value="{Binding Spec.Hard.Count}" />
        <c:PropertyItem Key="{x:Static assets:Resources.ResourceQuotaPropertiesView_Spec_Scopes}" Value="{Binding Spec.Scopes.Count}" />
        <c:PropertyItem Key="{x:Static assets:Resources.ResourceQuotaPropertiesView_Status_Hard}" Value="{Binding Status.Hard.Count}" />
        <c:PropertyItem Key="{x:Static assets:Resources.ResourceQuotaPropertiesView_Status_Used}" Value="{Binding Status.Used.Count}" />
    </StackPanel>
</UserControl>
