<UserControl
    x:Class="KubeUI.Avalonia.Controls.HeaderItem"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KubeUI.Avalonia.Controls"
    d:DesignHeight="30"
    d:DesignWidth="200">
    <StackPanel>
        <local:PropertyItem Key="{Binding Text, RelativeSource={RelativeSource AncestorType=local:HeaderItem}}" Value="">
            <local:PropertyItem.Styles>
                <Style Selector="SelectableTextBlock">
                    <Setter Property="Border.Background" Value="{DynamicResource SystemAltHighColor}" />
                    <Setter Property="Border.Padding" Value="8" />
                </Style>
            </local:PropertyItem.Styles>
        </local:PropertyItem>
        <ItemsControl ItemsSource="{Binding Controls, RelativeSource={RelativeSource AncestorType=local:HeaderItem}}" />
    </StackPanel>
</UserControl>



