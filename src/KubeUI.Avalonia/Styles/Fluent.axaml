<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:KubeUI.Avalonia.Converters"
    xmlns:core="using:Dock.Model.Core"
    xmlns:dock="using:Dock.Avalonia.Controls"
    xmlns:k="using:KubeUI"
    xmlns:u="https://irihi.tech/ursa">
    <Styles.Resources>
        <ResourceDictionary>
            <ControlTheme x:Key="DataGridFilterFlyoutPresenterTheme" TargetType="FlyoutPresenter" BasedOn="{StaticResource {x:Type FlyoutPresenter}}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
            </ControlTheme>
        </ResourceDictionary>
    </Styles.Resources>
    <Style Selector="DocumentControl">
        <Setter Property="HeaderTemplate">
            <DataTemplate x:DataType="core:IDockable" DataType="core:IDockable">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Rectangle
                        Width="10"
                        Height="10"
                        Margin="0,0,2,0"
                        Fill="{ReflectionBinding Cluster.ClusterColor}"
                        IsVisible="{ReflectionBinding Cluster, FallbackValue=False, Converter={x:Static converters:Converters.NotNull}}"
                        Stroke="Gray"
                        StrokeThickness="0.6"
                        ToolTip.Tip="{ReflectionBinding Cluster.Name}" />
                    <TextBlock
                        Padding="{DynamicResource DockHeaderContentPadding}"
                        VerticalAlignment="Center"
                        Text="{Binding Title}" />
                </StackPanel>
            </DataTemplate>
        </Setter>
    </Style>

    <Style Selector="dock|HostWindow:toolwindow">
        <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}" />
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RequestedThemeVariant" Value="{Binding RequestedThemeVariant, Source={x:Static Application.Current}}" />
        <Setter Property="TransparencyLevelHint" Value="None" />
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="RowHeight" Value="{DynamicResource DataGridRowHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridFontSize}" />
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="FontSize" Value="{DynamicResource DataGridFontSize}" />
        <Setter Property="MinHeight" Value="{DynamicResource DataGridColumnHeaderMinHeight}" />
    </Style>
    <Style Selector="DataGrid TextBlock">
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridFontSize}" />
    </Style>
    <Style Selector="DataGridSearchTextBlock#CellTextBlock">
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridFontSize}" />
    </Style>

    <Style Selector="StackPanel.filter-flyout-root">
        <Setter Property="MinWidth" Value="296" />
        <Setter Property="MaxWidth" Value="296" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Spacing" Value="8" />
        <Setter Property="Margin" Value="4" />
    </Style>
    <Style Selector="TextBlock.filter-flyout-title">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Grid.filter-flyout-row">
        <Setter Property="ColumnSpacing" Value="8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="TextBlock.filter-flyout-label">
        <Setter Property="Width" Value="72" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox.filter-flyout-editor">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="TextBox.filter-flyout-editor">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="NumericUpDown.filter-flyout-editor">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Grid.filter-flyout-composite-editor">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="StackPanel.filter-flyout-actions">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Spacing" Value="6" />
    </Style>
    <Style Selector="Button.filter-flyout-action">
        <Setter Property="MinWidth" Value="76" />
    </Style>

    <Style Selector="u|MultiComboBoxItem">
        <Setter Property="Padding" Value="4,2,4,2" />
        <Setter Property="Width" Value="200" />
        <Setter Property="MinHeight" Value="22" />
    </Style>
    <Style Selector="u|MultiComboBoxSelectedItemList">
        <Setter Property="Interaction.Behaviors">
            <BehaviorCollectionTemplate>
                <BehaviorCollection>
                    <EventTriggerBehavior EventName="PointerReleased">
                        <ChangePropertyAction
                            PropertyName="IsDropDownOpen"
                            TargetObject="{Binding $parent[u:MultiComboBox]}"
                            Value="{Binding !$parent[u:MultiComboBox].IsDropDownOpen}" />
                    </EventTriggerBehavior>
                </BehaviorCollection>
            </BehaviorCollectionTemplate>
        </Setter>
    </Style>
</Styles>
