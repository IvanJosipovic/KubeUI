<UserControl
    x:Class="KubeUI.Views.HomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assets="clr-namespace:KubeUI.Assets;assembly=KubeUI.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:KubeUI.Views"
    xmlns:vm="clr-namespace:KubeUI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:HomeViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:HomeViewModel />
    </Design.DataContext>

    <StackPanel>
        <Image
            Width="128"
            Height="128"
            Margin="0,15,0,0"
            Source="{SvgImage /Assets/kube/infrastructure_components/unlabeled/control-plane.svg}" />

        <TextBlock
            Margin="0,5,0,0"
            HorizontalAlignment="Center"
            FontSize="24"
            Text="{x:Static assets:Resources.HomeView_Header}" />
    </StackPanel>

</UserControl>


